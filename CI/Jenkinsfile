pipeline {
    agent { label 'windows' }

    options {
        timestamps()
        disableConcurrentBuilds(abortPrevious: true)
    }

    parameters {
        string(name: 'DOCKER_NAMESPACE', defaultValue: 'ajjsan', description: 'Docker Hub namespace/user')
        string(name: 'IMAGE_NAME', defaultValue: 'mle-template-api', description: 'Имя репозитория образа на Docker Hub')
        string(name: 'DOCKER_REGISTRY', defaultValue: 'docker.io', description: 'Реестр (обычно docker.io)')
        booleanParam(name: 'PUSH_IMAGE', defaultValue: true, description: 'Делать docker login + push образа')
        booleanParam(name: 'ONLY_MAIN_BRANCH', defaultValue: false, description: 'Если true — push только для сборок ветки main (НЕ PR), полезно для обычного Pipeline job')
        booleanParam(name: 'ONLY_PR_TO_MAIN', defaultValue: false, description: 'Если true — push только для PR, у которых target branch = main')
        booleanParam(name: 'TRIGGER_CD', defaultValue: true, description: 'После успешного push запустить CD job')
        string(name: 'CD_JOB', defaultValue: 'CD job', description: 'Имя CD job в Jenkins (например folder/cd-mle-api). Пусто = не запускать')
        string(name: 'CD_DEPLOY_TAG', defaultValue: '', description: 'Тег образа для CD (пусто = использовать тег из CI)')
    }

    environment {
        DOCKERHUB = credentials('dockerhub')
    }

    stages {
        stage('Preflight') {
            steps {
                script {
                    if (!env.CHANGE_ID) {
                        echo 'INFO: CHANGE_ID пустой — это не PR-сборка Multibranch. Для автоматизации по PR используйте Multibranch Pipeline + webhook.'
                    }
                }
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify model artifact (recommended)') {
            steps {
                powershell '''
                    if (-not (Test-Path -LiteralPath "experiments\\tfidf_log_reg.pkl")) {
                      Write-Error "ERROR: experiments\\tfidf_log_reg.pkl not found in workspace."
                      exit 1
                    }
                '''
            }
        }

        stage('Docker build') {
            steps {
                script {
                    withEnv([
                        "IMAGE_NAME=${params.IMAGE_NAME}",
                    ]) {
                        powershell '''
                            $shortSha = (git rev-parse --short HEAD).Trim()
                            docker build -t "$env:IMAGE_NAME:ci-$env:BUILD_NUMBER-$shortSha" .
                        '''
                    }
                }
            }
        }

        stage('Docker login + push') {
            when {
                expression { return params.PUSH_IMAGE.toBoolean() }
            }
            steps {
                script {
                    def isPr = env.CHANGE_ID?.trim() ? true : false

                    def branchSlug = (env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'branch')
                        .replaceFirst(/^origin\//, '')
                        .replaceAll(/[^A-Za-z0-9._-]+/, '-')
                        .replaceAll(/^-+|-+$/, '')

                    def gateOk = true
                    def gateReason = ''

                    if (params.ONLY_PR_TO_MAIN.toBoolean()) {
                        gateOk = isPr && (env.CHANGE_TARGET == 'main')
                        gateReason = 'ONLY_PR_TO_MAIN=true requires a PR build into main'
                    } else if (params.ONLY_MAIN_BRANCH.toBoolean()) {
                        def branchName = env.BRANCH_NAME ?: ''
                        def gitBranch = env.GIT_BRANCH ?: ''
                        def onMainBranch =
                            (branchName == 'main') ||
                            gitBranch.endsWith('/main') ||
                            (gitBranch == 'main')
                        gateOk = (!isPr) && onMainBranch
                        gateReason = 'ONLY_MAIN_BRANCH=true requires a non-PR build of main'
                    }

                    if (!gateOk) {
                        echo "SKIP push: ${gateReason} (CHANGE_ID=${env.CHANGE_ID}, CHANGE_TARGET=${env.CHANGE_TARGET}, BRANCH_NAME=${env.BRANCH_NAME}, GIT_BRANCH=${env.GIT_BRANCH})"
                        return
                    }

                    withEnv([
                        "DOCKER_REGISTRY=${params.DOCKER_REGISTRY}",
                        "DOCKER_NAMESPACE=${params.DOCKER_NAMESPACE}",
                        "IMAGE_NAME=${params.IMAGE_NAME}",
                    ]) {
                        def shortSha = powershell(script: "git rev-parse --short HEAD", returnStdout: true).trim()

                        def tagCi = null
                        if (isPr) {
                            tagCi = "pr-${env.CHANGE_ID}-${env.BUILD_NUMBER}-${shortSha}"
                        } else {
                            tagCi = "ci-${branchSlug}-${env.BUILD_NUMBER}-${shortSha}"
                        }

                        writeFile file: 'ci_tags.env', text: "TAG_CI=${tagCi}\n"
                        powershell """
                            docker tag "$env:IMAGE_NAME:ci-$env:BUILD_NUMBER-${shortSha}" "$env:DOCKER_NAMESPACE/$env:IMAGE_NAME:${tagCi}"
                            docker tag "$env:IMAGE_NAME:ci-$env:BUILD_NUMBER-${shortSha}" "$env:DOCKER_NAMESPACE/$env:IMAGE_NAME:latest"

                            $env:DOCKERHUB_PSW | docker login "$env:DOCKER_REGISTRY" -u "$env:DOCKERHUB_USR" --password-stdin

                            docker push "$env:DOCKER_NAMESPACE/$env:IMAGE_NAME:${tagCi}"
                            docker push "$env:DOCKER_NAMESPACE/$env:IMAGE_NAME:latest"
                        """
                    }
                }
            }
        }

        stage('Trigger CD') {
            when {
                allOf {
                    expression { return params.TRIGGER_CD.toBoolean() }
                    expression { return params.CD_JOB?.trim() }
                    expression { return params.PUSH_IMAGE.toBoolean() }
                }
            }
            steps {
                script {
                    def tag = params.CD_DEPLOY_TAG?.trim()
                    if (!tag) {
                        def props = readFile('ci_tags.env').split('\n').find { it.startsWith('TAG_CI=') }
                        tag = props?.replace('TAG_CI=', '')?.trim()
                    }
                    if (!tag) {
                        error('Cannot resolve tag for CD (ci_tags.env missing TAG_CI?)')
                    }

                    build job: params.CD_JOB.trim(), wait: false, parameters: [
                        string(name: 'IMAGE_NAME', value: params.IMAGE_NAME),
                        string(name: 'DOCKER_NAMESPACE', value: params.DOCKER_NAMESPACE),
                        string(name: 'DOCKER_REGISTRY', value: params.DOCKER_REGISTRY),
                        string(name: 'IMAGE_TAG', value: tag),
                        booleanParam(name: 'RUN_FUNCTIONAL_TESTS', value: true),
                        booleanParam(name: 'KEEP_STACK', value: false)
                    ]
                }
            }
        }
    }

    post {
        always {
            script {
                withEnv(["DOCKER_REGISTRY=${params.DOCKER_REGISTRY}"]) {
                    powershell '''
                        try {
                          docker logout "$env:DOCKER_REGISTRY" | Out-Null
                        } catch {
                          # ignore
                        }
                    '''
                }
            }
        }
    }
}
