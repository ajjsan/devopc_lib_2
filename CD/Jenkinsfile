pipeline {
    agent { label 'windows' }

    options {
        timestamps()
    }

    parameters {
        string(name: 'DOCKER_REGISTRY', defaultValue: 'docker.io', description: 'Реестр')
        string(name: 'DOCKER_NAMESPACE', defaultValue: 'ajjsan', description: 'Docker Hub namespace/user')
        string(name: 'IMAGE_NAME', defaultValue: 'mle-template-api', description: 'Имя образа')
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Тег образа')

        string(name: 'HOST_PORT', defaultValue: '8000', description: 'Порт API на хосте агента')
        string(
            name: 'COMPOSE_PROJECT_NAME',
            defaultValue: 'mle-cd',
            description: 'Имя проекта docker compose (изоляция на агенте)'
        )

        string(
            name: 'CRED_ID_JWT',
            defaultValue: 'mle-cd-jwt-secret',
            description: 'Secret text: JWT_SECRET_KEY'
        )
        string(
            name: 'CRED_ID_API',
            defaultValue: 'mle-cd-api-auth',
            description: 'Username with password: API'
        )
        string(
            name: 'CRED_ID_POSTGRES',
            defaultValue: 'mle-cd-postgres',
            description: 'Username with password: Postgres (POSTGRES_USER / POSTGRES_PASSWORD)'
        )
        string(
            name: 'CRED_ID_POSTGRES_DB',
            defaultValue: 'mle-cd-postgres-db',
            description: 'Secret text: имя БД (POSTGRES_DB)'
        )

        booleanParam(name: 'RUN_FUNCTIONAL_TESTS', defaultValue: true, description: 'Запуск scripts/functional_test_api.py')
        booleanParam(name: 'KEEP_STACK', defaultValue: false, description: 'Если true — не останавливать compose и не удалять volume после прогона')
    }

    environment {
        DOCKERHUB = credentials('dockerhub')
    }

    stages {
        stage('Checkout (compose + tests)') {
            steps {
                checkout scm
            }
        }

        stage('Docker login + pull API image') {
            steps {
                script {
                    withEnv([
                        "DOCKER_REGISTRY=${params.DOCKER_REGISTRY}",
                        "DOCKER_NAMESPACE=${params.DOCKER_NAMESPACE}",
                        "IMAGE_NAME=${params.IMAGE_NAME}",
                        "IMAGE_TAG=${params.IMAGE_TAG}",
                    ]) {
                        powershell '''
                            $env:DOCKERHUB_PSW | docker login "$env:DOCKER_REGISTRY" -u "$env:DOCKERHUB_USR" --password-stdin
                            docker pull "$env:DOCKER_NAMESPACE/$env:IMAGE_NAME`:$env:IMAGE_TAG"
                        '''
                    }
                }
            }
        }

        stage('Compose down (previous run)') {
            when {
                expression { return !params.KEEP_STACK.toBoolean() }
            }
            steps {
                script {
                    withEnv(["COMPOSE_PROJECT_NAME=${params.COMPOSE_PROJECT_NAME}"]) {
                        powershell '''
                            try {
                              docker compose -f docker-compose.jenkins.yml -p "$env:COMPOSE_PROJECT_NAME" down -v --remove-orphans | Out-Null
                            } catch {
                              # ignore
                            }
                        '''
                    }
                }
            }
        }

        stage('Compose up (Postgres + API)') {
            steps {
                script {
                    withCredentials([
                        string(credentialsId: params.CRED_ID_JWT, variable: 'JWT_SECRET_KEY'),
                        usernamePassword(
                            credentialsId: params.CRED_ID_API,
                            usernameVariable: 'API_USERNAME',
                            passwordVariable: 'API_PASSWORD'
                        ),
                        usernamePassword(
                            credentialsId: params.CRED_ID_POSTGRES,
                            usernameVariable: 'POSTGRES_USER',
                            passwordVariable: 'POSTGRES_PASSWORD'
                        ),
                        string(credentialsId: params.CRED_ID_POSTGRES_DB, variable: 'POSTGRES_DB'),
                    ]) {
                        withEnv([
                            "DOCKER_NAMESPACE=${params.DOCKER_NAMESPACE}",
                            "IMAGE_NAME=${params.IMAGE_NAME}",
                            "IMAGE_TAG=${params.IMAGE_TAG}",
                            "HOST_PORT=${params.HOST_PORT}",
                            "COMPOSE_PROJECT_NAME=${params.COMPOSE_PROJECT_NAME}",
                        ]) {
                            powershell '''
                                $env:MLE_DOCKER_IMAGE = "$env:DOCKER_NAMESPACE/$env:IMAGE_NAME`:$env:IMAGE_TAG"
                                docker compose -f docker-compose.jenkins.yml -p "$env:COMPOSE_PROJECT_NAME" up -d
                                Start-Sleep -Seconds 8
                            '''
                        }
                    }
                }
            }
        }

        stage('Functional tests') {
            when {
                expression { return params.RUN_FUNCTIONAL_TESTS.toBoolean() }
            }
            steps {
                script {
                    withCredentials([
                        usernamePassword(
                            credentialsId: params.CRED_ID_API,
                            usernameVariable: 'API_USERNAME',
                            passwordVariable: 'API_PASSWORD'
                        ),
                    ]) {
                        withEnv([
                            "HOST_PORT=${params.HOST_PORT}",
                        ]) {
                            powershell '''
                                python scripts/functional_test_api.py --base-url "http://127.0.0.1:$env:HOST_PORT" --timeout 180
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if (!params.KEEP_STACK.toBoolean()) {
                    withEnv(["COMPOSE_PROJECT_NAME=${params.COMPOSE_PROJECT_NAME}"]) {
                        powershell '''
                            try {
                              docker compose -f docker-compose.jenkins.yml -p "$env:COMPOSE_PROJECT_NAME" down -v --remove-orphans | Out-Null
                            } catch {
                              # ignore
                            }
                        '''
                    }
                }
                withEnv(["DOCKER_REGISTRY=${params.DOCKER_REGISTRY}"]) {
                    powershell '''
                        try {
                          docker logout "$env:DOCKER_REGISTRY" | Out-Null
                        } catch {
                          # ignore
                        }
                    '''
                }
            }
        }
    }
}
