# Скопируй в .env. Репозиторий не должен содержать реальный .env с секретами.

# PostgreSQL (одинаковые значения для сервисов db и api; пароль может содержать @, &, % и т.д.)
POSTGRES_USER=myuser
POSTGRES_PASSWORD=my_password_can_include_@_and_&
POSTGRES_DB=mydb
POSTGRES_PORT=5432

# Для API на хосте без Docker. В docker-compose для сервиса api задаётся POSTGRES_HOST=db.
POSTGRES_HOST=localhost

# Полный URL (необязательно). Если задан — перекрывает POSTGRES_* (удобно для тестов):
# DATABASE_URL=sqlite:///:memory:

# Если сменил POSTGRES_USER / POSTGRES_DB после первого запуска, старый кластер в volume
# останется со старыми ролями. Сброс данных: docker compose down -v

# JWT (случайная длинная строка; в .env символ % для Docker Compose иногда нужно удваивать как %%)
JWT_SECRET_KEY=replace_with_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OAuth2: username / password для POST /auth/token
API_USERNAME=api_user
API_PASSWORD=replace_with_strong_password
